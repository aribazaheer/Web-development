<!DOCTYPE html>
<html>
<head>
    <title>Internal CSS Example</title>

    <style>
        body {
            font-family: Arial;
        }

        table {
            width: 50%;
            border-collapse: collapse;
        }

        th, td {
            border: 1px solid black;
            padding: 10px;
            text-align: center;
        }

        th {
            background-color: lightblue;
        }
    </style>

</head>
<body>

<h2>Student Table</h2>

<table>
    <tr>
        <th>Name</th>
        <th>Age</th>
        <th>City</th>
    </tr>

    <tr>
        <td>Ali</td>
        <td>20</td>
        <td>Islamabad</td>
    </tr>

    <tr>
        <td>Sara</td>
        <td>22</td>
        <td>Lahore</td>
    </tr>
</table>

</body>
</html>